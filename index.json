          "angular.json present",
          "*.component.ts files"
        ],
        "requires": [
          "ts",
          "node"
        ],
        "commands": {
          "build": "ng build",
          "test": "ng test --watch=false",
          "lint": "ng lint",
          "run": "ng serve"
        }
      }
    },
