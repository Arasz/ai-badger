{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Arasz/ai-badger/schemas/index.schema.json",
  "title": "ai-badger feature index",
  "description": "Source-of-truth catalog of every feature for every stack (plus common), generated by index_build.py from the repo tree.",
  "type": "object",
  "required": ["frameworkVersion", "stacks"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "frameworkVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "stacks": {
      "type": "object",
      "description": "Keyed by stack name; 'common' holds stack-agnostic features.",
      "propertyNames": { "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "meta": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "description": { "type": "string" },
              "detectionSignals": { "type": "array", "items": { "type": "string" } },
              "requires": { "type": "array", "items": { "type": "string" } },
              "commands": { "type": "object", "additionalProperties": { "type": "string" } }
            }
          },
          "skills": { "$ref": "#/$defs/featureList" },
          "personas": { "$ref": "#/$defs/featureList" },
          "invariants": { "$ref": "#/$defs/featureList" },
          "instructions": { "$ref": "#/$defs/featureList" },
          "templates": { "$ref": "#/$defs/featureList" },
          "hooks": { "$ref": "#/$defs/featureList" },
          "adjustments": { "$ref": "#/$defs/featureList" }
        }
      }
    }
  },
  "$defs": {
    "featureList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "extensions": { "type": "array", "items": { "type": "string" } },
          "external": { "type": "boolean", "description": "True for external skills referenced in skills.json." },
          "detectionSignals": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Glob/filename hints used by detect.py to auto-select the owning stack."
          },
          "commands": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Suggested build/test/lint/run commands this stack contributes."
          }
        }
      }
    }
  }
}
